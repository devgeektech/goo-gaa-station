{
  "expo": {
    "name": "DeliverEats Vendor",
    "slug": "vendor-app",
    "version": "1.0.0",
    "scheme": "delivereats-vendor",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": { "supportsTablet": true, "bundleIdentifier": "com.delivereats.vendor" },
    "android": { "package": "com.delivereats.vendor" },
    "plugins": ["expo-router"],
    "extra": {
      "apiUrl": "${EXPO_PUBLIC_API_URL}",
      "socketUrl": "${EXPO_PUBLIC_SOCKET_URL}"
    }
  }
}
