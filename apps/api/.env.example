NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/delivereats
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
STORAGE_PROVIDER=local
# Use s3 for AWS S3 uploads (requires all AWS_* below). Images are stored as public HTTPS URLs.
# STORAGE_PROVIDER=s3
UPLOAD_DIR=uploads
AWS_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
# Optional: CDN or custom public base (no trailing slash), e.g. https://d123.cloudfront.net
# AWS_S3_PUBLIC_BASE_URL=
# Optional: MinIO / custom S3-compatible endpoint (uses path-style addressing)
# AWS_S3_ENDPOINT=
WIFIPAY_API_URL=
WIFIPAY_API_KEY=
WIFIPAY_WEBHOOK_SECRET=
ADMIN_DEFAULT_EMAIL=admin@deliveryapp.com
ADMIN_DEFAULT_PASSWORD=Admin@12345
CLIENT_ORIGIN=http://localhost:3000
# Optional: vendor list ETA/distance (enable Distance Matrix API for this key in Google Cloud).
GOOGLE_DISTANCE_MATRIX_API_KEY=
# Optional: comma-separated CORS origins (e.g. http://localhost:3000,https://admin.example.com). If set, overrides single CLIENT_ORIGIN.
# ALLOWED_ORIGINS=
 
# Email (Mailtrap dev / SendGrid or SES prod) — uncomment when needed
# MAIL_PROVIDER=mailtrap
# SMTP_HOST=
# SMTP_PORT=2525
# SMTP_USER=
# SMTP_PASS=
# SENDGRID_API_KEY=
 
# FCM (Firebase Admin) — path to service account JSON file or inline JSON string (uncomment when needed)
# FIREBASE_SERVICE_ACCOUNT=
 
# Twilio WhatsApp OTP. SID + token must be from the same Console project where Messaging → WhatsApp is enabled.
# Use TWILIO_WHATSAPP_FROM = sandbox sender from Console (often +14155238886), OR leave empty and set TWILIO_MESSAGING_SERVICE_SID.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
# TWILIO_MESSAGING_SERVICE_SID=
# Optional: same OTP via SMS when WhatsApp sandbox does not show messages (use a Twilio SMS-capable number from Phone Numbers).
# TWILIO_SMS_FROM=