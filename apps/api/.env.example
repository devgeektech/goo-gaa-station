NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/delivereats
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
STORAGE_PROVIDER=local
UPLOAD_DIR=uploads
AWS_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
WIFIPAY_API_URL=
WIFIPAY_API_KEY=
WIFIPAY_WEBHOOK_SECRET=
ADMIN_DEFAULT_EMAIL=admin@deliveryapp.com
ADMIN_DEFAULT_PASSWORD=Admin@12345
CLIENT_ORIGIN=http://localhost:3000
# Optional: comma-separated CORS origins (e.g. http://localhost:3000,https://admin.example.com). If set, overrides single CLIENT_ORIGIN.
# ALLOWED_ORIGINS=
 
# Email (Mailtrap dev / SendGrid or SES prod) — uncomment when needed
# MAIL_PROVIDER=mailtrap
# SMTP_HOST=
# SMTP_PORT=2525
# SMTP_USER=
# SMTP_PASS=
# SENDGRID_API_KEY=
 
# FCM (Firebase Admin) — path to service account JSON file or inline JSON string (uncomment when needed)
# FIREBASE_SERVICE_ACCOUNT=
 
# Twilio WhatsApp OTP — uncomment and set when using send-otp via WhatsApp
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=14155238886